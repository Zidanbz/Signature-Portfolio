# Option 1: Direct JSON endpoint returning portfolio data
# SHEET_URL=https://example.com/portfolio.json

# Option 2: Public Google Spreadsheet ID (recommended)
# The sheet must have tabs:
# Profile, Projects, Experience, Achievements, Skills, Certifications
GOOGLE_SHEET_ID=

# Optional: disable fetch cache (useful for testing spreadsheet changes quickly)
# SHEET_DISABLE_CACHE=true
